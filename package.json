{
  "name": "sdk-root",
  "version": "0.0.0",
  "private": true,
  "description": "Sanity SDK for Content OS",
  "keywords": [],
  "homepage": "https://github.com/sanity-io/sdk#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/sdk.git"
  },
  "license": "MIT",
  "author": "Sanity <developers@sanity.io>",
  "sideEffects": false,
  "scripts": {
    "all": "turbo run build && turbo run lint && turbo run test:coverage && pnpm build:docs && pnpm depcheck",
    "build": "turbo run build --filter='./packages/*' --filter='./apps/*'",
    "build:bundle": "turbo run build:bundle --filter='./packages/*' --filter='!./packages/@repo/*'",
    "build:docs": "turbo run docs && typedoc",
    "build:packages": "turbo run build --filter='./packages/*' --filter='!./packages/@repo/*'",
    "build:visualizer": "VISUALIZER=true turbo run build --filter='./packages/*'",
    "clean": "run-s clean:build clean:deps",
    "clean:build": "turbo run clean",
    "clean:deps": "rimraf packages/*/node_modules apps/*/node_modules node_modules",
    "cleanup:e2e": "turbo run cleanup --filter=@repo/e2e",
    "depcheck": "DEPCHECK=true knip",
    "deploy:kitchensink": "turbo run deploy --filter=@sanity/kitchensink-react",
    "dev": "pnpm dev:kitchensink",
    "dev:e2e": "SANITY_INTERNAL_ENV=staging SDK_E2E_ORGANIZATION_ID=oFvj4MZWQ turbo run dev --filter=@sanity/kitchensink-react",
    "dev:kitchensink": "turbo run dev --filter=@sanity/kitchensink-react",
    "dev:standalone": "turbo run dev --filter=@sanity/standalone-react",
    "fallow": "fallow",
    "fallow:audit": "fallow audit --base origin/main",
    "fallow:baseline": "run-s --continue-on-error fallow:baseline:* || true",
    "fallow:baseline:dead-code": "fallow dead-code --save-baseline fallow-baselines/dead-code.json --quiet",
    "fallow:baseline:dupes": "fallow dupes --save-baseline fallow-baselines/dupes.json --quiet",
    "fallow:baseline:health": "fallow health --save-baseline fallow-baselines/health.json --quiet",
    "fallow:hotspots": "fallow health --hotspots --ownership --production --quiet",
    "fallow:summary": "fallow --summary --quiet",
    "fallow:targets": "fallow health --targets --quiet",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint": "turbo run lint -- --fix && eslint . --fix",
    "prepare": "husky",
    "release:current-branch": "tsx scripts/release-branch.mts",
    "release:rc": "tsx scripts/release-rc.mts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "open coverage/index.html",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:dashboard": "turbo run test:e2e --filter=@sanity/kitchensink-react -- --project=chromium --project=firefox",
    "test:e2e:webkit": "turbo run test:e2e --filter=@sanity/kitchensink-react -- --project=webkit",
    "test:kitchensink": "turbo run test --filter=@sanity/kitchensink-react",
    "test:watch": "vitest watch",
    "ts:check": "turbo run ts:check --filter='./packages/*' --filter='./apps/*'",
    "upload:bundles": "tsx scripts/uploadBundles.mts"
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@google-cloud/storage": "^7.19.0",
    "@playwright/test": "^1.60.0",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-test": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@sanity/pkg-utils": "^9.2.3",
    "@sanity/prettier-config": "^1.0.6",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^9.39.4",
    "fallow": "^2.48.4",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "read-package-up": "^12.0.0",
    "rimraf": "^6.0.1",
    "tsx": "<4.22.0",
    "turbo": "^2.9.14",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "overrides": {
      "@babel/types": "7.29.0",
      "basic-ftp@<5.3.1": "^5.3.1",
      "form-data@<2.5.4": "^2.5.4",
      "tsx": "<4.22.0"
    }
  }
}
