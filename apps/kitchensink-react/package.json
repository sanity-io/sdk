{
  "name": "@sanity/kitchensink-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm tsc && vite build",
    "clean": "rimraf dist",
    "deploy": "sanity deploy",
    "dev": "sanity dev",
    "install": "npm run schema:extract && npm run types:generate",
    "lint": "eslint .",
    "paramour": "npx paramour --config=./src/css/css.config.js --output=./src/css/paramour.css",
    "preview": "vite preview",
    "schema:extract": "./node_modules/@sanity/cli-v3/bin/sanity schema extract --workspace ppsg7ml5-test --path schema.ppsg7ml5.test.json && ./node_modules/@sanity/cli-v3/bin/sanity schema extract --workspace vo1ysemo-production --path schema.vo1ysemo.production.json",
    "test:e2e": "playwright test",
    "tsc": "tsc --noEmit",
    "types:generate": "./node_modules/@sanity/cli-v3/bin/sanity typegen generate"
  },
  "prettier": "@sanity/prettier-config",
  "dependencies": {
    "@paramour/css": "1.0.0-rc.2",
    "@sanity/icons": "^3.7.4",
    "@sanity/sdk-react": "workspace:*",
    "@sanity/ui": "^2.16.22",
    "groq": "catalog:",
    "inter-ui": "^4.1.1",
    "json-edit-react": "^1.29.1",
    "react": "catalog:",
    "react-compiler-runtime": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "catalog:",
    "react-router": "^7.15.1",
    "sanity": "5.14.1",
    "styled-components": "^6.4.1",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@repo/config-eslint": "workspace:*",
    "@repo/e2e": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@sanity/cli": "5.14.1",
    "@sanity/cli-v3": "npm:@sanity/cli@3.88.1-typegen-experimental.0",
    "@sanity/prettier-config": "catalog:",
    "@sanity/sdk": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
