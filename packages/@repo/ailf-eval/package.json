{
  "name": "@repo/ailf-eval",
  "version": "0.0.1",
  "private": true,
  "description": "AI Literacy Framework evaluation config and tasks for the SDK docs",
  "type": "module",
  "scripts": {
    "eval": "ailf run --mode literacy --variant baseline --remote",
    "improve-docs": "node --env-file-if-exists=../../../.env.local scripts/improve-docs.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "@sanity/ailf": "^7.6.0"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
